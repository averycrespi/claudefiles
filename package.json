{
  "name": "agent-config",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@eslint/js": "^10.0.1",
    "@sinclair/typebox": "^0.34.0",
    "@types/turndown": "^5.0.6",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typebox": "^1.1.38",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.2",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.5.0",
    "linkedom": "^0.18.0",
    "turndown": "^7.2.0",
    "unpdf": "^1.4.0"
  },
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "lint": "eslint \"pi/agent/extensions/**/*.ts\"",
    "typecheck": "tsc",
    "test": "tsx --test \"pi/agent/extensions/**/*.test.ts\""
  },
  "lint-staged": {
    "pi/agent/extensions/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": "prettier --write",
    "{claude,pi}/**/*.{json,md,yml,yaml}": "prettier --write"
  }
}
