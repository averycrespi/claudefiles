    "deny": [
      "Read(~/.aws/**)",
      "Read(~/.bash_secrets)",
      "Read(~/.config/gh/**)",
      "Read(~/.docker/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.ssh/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scan-secrets-before-commit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-on-write"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-on-write"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude needs your attention' -message \"$PWD\" && afplay /System/Library/Sounds/Ping.aiff",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude is done' -message \"$PWD\" && afplay /System/Library/Sounds/Glass.aiff",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {},
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "bitbucket.org",
        "files.pythonhosted.org",
        "github.com",
        "gitlab.com",
        "golang.org",
        "gopkg.in",
        "index.golang.org",
        "proxy.golang.org",
        "pypi.org",
        "registry.npmjs.org",
        "storage.googleapis.com",
        "sum.golang.org"
      ]
    },
    "excludedCommands": [
      "aws:*",
      "docker:*",
      "docker-compose:*",
      "gh:*",
      "git:*",
      "go build:*",
      "go install:*",
      "go test:*",
      "launchctl:*",
      "playwright-cli:*"
    ]
  }
}
