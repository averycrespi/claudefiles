{
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Read(~/.claude/skills/**)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "Edit(//tmp/**)",
      "Edit(//private/tmp/**)",
      "Write(//tmp/**)",
      "Write(//private/tmp/**)",
      "Bash(cd:*)",
      "Bash(cut:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(launchctl list:*)",
      "Bash(launchctl print:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mkdir -p:*)",
      "Bash(pandoc:*)",
      "Bash(plutil -lint:*)",
      "Bash(pwd:*)",
      "Bash(rg:*)",
      "Bash(sort:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(type:*)",
      "Bash(uniq:*)",
      "Bash(which:*)",
      "Bash(wc:*)",
      "Bash(gh api:*)",
      "Bash(gh cache list:*)",
      "Bash(gh gist list:*)",
      "Bash(gh gist view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh issue view:*)",
      "Bash(gh label list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh project field-list:*)",
      "Bash(gh project item-list:*)",
      "Bash(gh project list:*)",
      "Bash(gh project view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh ruleset check:*)",
      "Bash(gh ruleset list:*)",
      "Bash(gh ruleset view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh search code:*)",
      "Bash(gh search commits:*)",
      "Bash(gh search issues:*)",
      "Bash(gh search prs:*)",
      "Bash(gh search repos:*)",
      "Bash(gh status:*)",
      "Bash(gh variable get:*)",
      "Bash(gh variable list:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(git add:*)",
      "Bash(git blame:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git mv:*)",
      "Bash(git remote get-url:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rm:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git -C * add *)",
      "Bash(git -C * blame *)",
      "Bash(git -C * commit *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * log *)",
      "Bash(git -C * mv *)",
      "Bash(git -C * remote get-url *)",
      "Bash(git -C * rev-parse *)",
      "Bash(git -C * rm *)",
      "Bash(git -C * show *)",
      "Bash(git -C * status *)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(go list:*)",
      "Bash(go mod graph:*)",
      "Bash(go mod tidy:*)",
      "Bash(go mod verify:*)",
      "Bash(go mod why:*)",
      "Bash(go test:*)",
      "Bash(go version:*)",
      "Bash(go vet:*)",
      "Bash(playwright-cli:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)",
      "Skill(automating-browsers)",
      "Skill(brainstorming)",
      "Skill(completing-work)",
      "Skill(creating-jira-tickets)",
      "Skill(creating-skills)",
      "Skill(designing-frontends)",
      "Skill(executing-plans)",
      "Skill(executing-plans-quickly)",
      "Skill(following-tdd)",
      "Skill(managing-launchd-agents)",
      "Skill(researching)",
      "Skill(reviewing-prs)",
      "Skill(troubleshooting)",
      "Skill(verifying-work)",
      "Skill(writing-plans)"
    ],
    "deny": [
      "Read(~/.aws/**)",
      "Read(~/.bash_secrets)",
      "Read(~/.config/gh/**)",
      "Read(~/.docker/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.ssh/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scan-secrets-before-commit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-markdown"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-markdown"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude needs your attention' -message \"$PWD\" && afplay /System/Library/Sounds/Ping.aiff",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude is done' -message \"$PWD\" && afplay /System/Library/Sounds/Glass.aiff",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "excludedCommands": [
      "aws:*",
      "docker:*",
      "docker-compose:*",
      "gh:*",
      "git:*",
      "go build:*",
      "go install:*",
      "go test:*",
      "launchctl:*",
      "playwright-cli:*"
    ],
    "network": {
      "allowedDomains": [
        "bitbucket.org",
        "files.pythonhosted.org",
        "github.com",
        "gitlab.com",
        "golang.org",
        "gopkg.in",
        "index.golang.org",
        "proxy.golang.org",
        "pypi.org",
        "storage.googleapis.com",
        "sum.golang.org"
      ]
    }
  }
}
