#!/bin/bash
set -euo pipefail

INPUT=$(cat)
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command')

# Strip quoted substrings so commit messages, PR bodies, etc. don't trigger
# false matches on `gh ` appearing inside text.
STRIPPED=$(echo "$COMMAND" | sed -E "s/'[^']*'//g; s/\"[^\"]*\"//g")

# Only intercept gh CLI invocations
if ! echo "$STRIPPED" | grep -qE '(^|\s|;|&&|\|\||\|)gh\s'; then
	exit 0
fi

jq -n '{
  hookSpecificOutput: {
    hookEventName: "PreToolUse",
    permissionDecision: "allow",
    additionalContext: "Hint: the gh CLI is not authenticated in this sandbox and will fail. For GitHub operations, prefer MCP tools instead."
  }
}'
