#!/bin/bash
set -euo pipefail

INPUT=$(cat)
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command')

# Only intercept gh CLI commands
if ! echo "$COMMAND" | grep -qE '(^|\s|;|&&|\|\|)gh\s'; then
	exit 0
fi

jq -n '{
  hookSpecificOutput: {
    hookEventName: "PreToolUse",
    permissionDecision: "deny",
    permissionDecisionReason: "The GitHub CLI (gh) is not authenticated in this environment. Instead, use MCP tools to access GitHub."
  }
}'
