#!/bin/bash
set -euo pipefail

INPUT=$(cat)
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command')

# Strip quoted substrings so commit messages, PR bodies, etc. don't trigger
# false matches on `git push` etc. appearing inside text.
STRIPPED=$(echo "$COMMAND" | sed -E "s/'[^']*'//g; s/\"[^\"]*\"//g")

# Only intercept git remote operations
if ! echo "$STRIPPED" | grep -qE '(^|\s|;|&&|\|\||\|)git\s+(push|pull|fetch|ls-remote|remote)\b'; then
	exit 0
fi

jq -n '{
  hookSpecificOutput: {
    hookEventName: "PreToolUse",
    permissionDecision: "allow",
    additionalContext: "Hint: git remote operations are not available in this sandbox and will fail. For interacting with git remotes, prefer MCP tools instead."
  }
}'
