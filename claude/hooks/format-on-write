#!/bin/bash
set -euo pipefail

INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path')

# Only format if file exists (handles failed writes)
if [[ ! -f "$FILE_PATH" ]]; then
  exit 0
fi

# Determine formatter based on file extension
case "$FILE_PATH" in
  *.md|*.json|*.yaml|*.yml|*.js|*.ts|*.jsx|*.tsx|*.css|*.html|*.graphql)
    FORMATTER_BIN="npx"
    FORMATTER_CMD=(npx prettier --write "$FILE_PATH")
    ;;
  *.go)
    FORMATTER_BIN="gofmt"
    FORMATTER_CMD=(gofmt -w "$FILE_PATH")
    ;;
  *.rs)
    FORMATTER_BIN="rustfmt"
    FORMATTER_CMD=(rustfmt "$FILE_PATH")
    ;;
  *.sh|*.bash)
    FORMATTER_BIN="shfmt"
    FORMATTER_CMD=(shfmt -w "$FILE_PATH")
    ;;
  *)
    exit 0
    ;;
esac

# Check if formatter is available
if ! command -v "$FORMATTER_BIN" >/dev/null 2>&1; then
  jq -n --arg msg "format-on-write: $FORMATTER_BIN not found, skipping $FILE_PATH" '{systemMessage: $msg}'
  exit 0
fi

"${FORMATTER_CMD[@]}" >/dev/null 2>&1
exit 0
