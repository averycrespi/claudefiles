#!/bin/bash
set -euo pipefail

INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path')

# Only format markdown files
if [[ "$FILE_PATH" != *.md ]]; then
  exit 0
fi

# Only format if file exists (handles failed writes)
if [[ ! -f "$FILE_PATH" ]]; then
  exit 0
fi

npx prettier --write "$FILE_PATH" >/dev/null 2>&1
exit 0
