#!/bin/bash
# bash-pattern-guard: Rejects Bash commands containing patterns that trigger
# Claude Code's built-in safety heuristics, which cannot be suppressed via
# allow rules and require manual user intervention.
#
# Exit 2 + stderr = block the command and tell Claude why
# Exit 1 = no pattern detected, fall through to normal permission checking

set -uo pipefail

INPUT=$(cat)
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command // empty')

if [ -z "$COMMAND" ]; then
	exit 1
fi

# --- Pattern checks ---
# Each check prints guidance to stderr and exits 2 if triggered.

# $() command substitution
if echo "$COMMAND" | grep -qF '$('; then
	cat >&2 <<'MSG'
BLOCKED: Command contains $() command substitution, which triggers a
non-suppressible safety prompt in Claude Code.

Instead of using $() for multi-line content, write to a temp file first:

For git commits:
  git commit -m "subject" -m "body paragraph"
  Or: use the Write tool to create $TMPDIR/msg.txt, then:
  git commit -F $TMPDIR/msg.txt

For gh pr create / gh issue create:
  Use the Write tool to create $TMPDIR/body.md, then:
  gh pr create --title "title" --body-file $TMPDIR/body.md

For any command needing inline output:
  Run the inner command separately and capture its output first.
MSG
	exit 2
fi

# Backtick command substitution
# Allow backticks inside single-quoted strings (common in markdown/jq)
OUTSIDE_SINGLE_QUOTES=$(echo "$COMMAND" | sed "s/'[^']*'//g")
if echo "$OUTSIDE_SINGLE_QUOTES" | grep -q '`'; then
	cat >&2 <<'MSG'
BLOCKED: Command contains backticks (`) for command substitution, which
triggers a non-suppressible safety prompt in Claude Code.

Instead of:
  echo `some_command`

Do this:
  some_command

If you need the output in a variable, write a script file instead.
MSG
	exit 2
fi

# Newlines in command
LINE_COUNT=$(echo "$COMMAND" | wc -l | tr -d ' ')
if [ "$LINE_COUNT" -gt 1 ]; then
	cat >&2 <<'MSG'
BLOCKED: Command contains newlines, which triggers a non-suppressible
safety prompt in Claude Code ("Command contains newlines that could
separate multiple commands").

Instead of multi-line commands:
- Chain with && on a single line
- Write a script file with the Write tool, then run it with Bash
- Use separate sequential Bash tool calls for each command
MSG
	exit 2
fi

# Heredoc delimiters (<<'EOF', <<"EOF", <<EOF)
if echo "$COMMAND" | grep -qE '<<-?\s*'\''?[A-Za-z_]+'\''?'; then
	cat >&2 <<'MSG'
BLOCKED: Command contains a heredoc (<<EOF or <<'EOF'), which triggers
non-suppressible safety prompts in Claude Code for both "consecutive
quote characters at word start" and "newlines" patterns.

Instead of heredocs:
- Use the Write tool to create a file, then read/execute it
- For git commits, use -m "subject" -m "body" flags
- For gh commands, use --body-file with a file created via Write tool
MSG
	exit 2
fi

# ANSI-C quoting ($'...')
# Also catches false positives like: grep '\.json$' (where $' spans tokens)
if echo "$COMMAND" | grep -qE "\\\$'"; then
	cat >&2 <<'MSG'
BLOCKED: Command contains what looks like ANSI-C quoting ($'...'),
which triggers a non-suppressible safety prompt in Claude Code.

This also fires on false positives like: grep '\.json$' followed by
another single quote.

Instead of:
  echo $'\t'

Do this:
  printf '\t'

If this is a regex ending in $, restructure the quoting:
  grep -E "\.json$"   (use double quotes instead)
MSG
	exit 2
fi

# Quoted strings that look like flag names ("--something" or "-x")
# This catches: echo "---", --flag "value" where the quoted value starts with -
if echo "$COMMAND" | grep -qE '"--?[a-zA-Z-]*"'; then
	cat >&2 <<'MSG'
BLOCKED: Command contains quoted characters that look like flag names
(e.g., "---" or "--flag"), which triggers a non-suppressible safety
prompt in Claude Code.

Instead of:
  echo "---"

Do this:
  printf '%s\n' '---'

Or avoid quoting strings that start with dashes.
MSG
	exit 2
fi

# No patterns detected — fall through to normal permission checking
exit 1
